<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".TrackingActivity">

    <!-- Map Placeholder (Top 40%) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/infoSheet"
        app:layout_constraintVertical_weight="0.4">
        
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_launcher_background"
            android:scaleType="centerCrop"
            app:tint="#CFD8DC"/> <!-- Map placeholder color -->
            
        <!-- Pins Overlay Placeholder -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_location"
            app:tint="@color/app_primary"
            android:layout_gravity="center"/>
    </FrameLayout>
    
    <!-- Info Sheet (Bottom 60% approx, sliding up effect simulated via static layout) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/infoSheet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/header_barrier" 
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_weight="0.6"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        android:layout_marginTop="-24dp"> <!-- Overlap map slightly -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Handle Bar -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#E0E0E0"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"/>

            <!-- Cleaner Profile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">
                
                <androidx.cardview.widget.CardView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:cardCornerRadius="30dp"
                    app:cardElevation="0dp">
                     <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_launcher_background"
                        app:tint="#BDBDBD"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="John Cleaner"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.9 ★"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>

                <ImageButton
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_call"
                    android:background="@drawable/bg_white_rounded" 
                    android:backgroundTint="@color/app_primary"
                    app:tint="@color/white"/>
            </LinearLayout>

            <!-- Arriving Time -->
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Arriving in 15 mins"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/app_accent"
                android:layout_marginBottom="24dp"/>

            <!-- Timeline (Simplified) -->
             <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Step 1: Confirmed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="0dp">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check_circle" app:tint="@color/app_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Booking Confirmed" android:layout_marginStart="16dp" android:textColor="@color/text_primary"/>
                </LinearLayout>
                <View android:layout_width="2dp" android:layout_height="24dp" android:background="@color/app_primary" android:layout_marginStart="11dp"/>

                 <!-- Step 2: On the Way (Active) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                     <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check_circle" app:tint="@color/app_accent"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cleaner is on the way" android:layout_marginStart="16dp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                </LinearLayout>
                 <View android:layout_width="2dp" android:layout_height="24dp" android:background="#E0E0E0" android:layout_marginStart="11dp"/>
                
                 <!-- Step 3 -->
                  <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                     <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_white_rounded" android:backgroundTint="#E0E0E0" android:layout_margin="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cleaning in Progress" android:layout_marginStart="22dp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
                 <View android:layout_width="2dp" android:layout_height="24dp" android:background="#E0E0E0" android:layout_marginStart="11dp"/>

                <!-- Step 4 -->
                  <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                     <View android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/bg_white_rounded" android:backgroundTint="#E0E0E0" android:layout_margin="6dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Service Completed" android:layout_marginStart="22dp" android:textColor="@color/text_secondary"/>
                </LinearLayout>

             </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/header_barrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="infoSheet" />

</androidx.constraintlayout.widget.ConstraintLayout>
