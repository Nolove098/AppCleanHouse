<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_50">

    <!-- Full-page scroll: hero + content all inside NSV so negative margins work -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== COLORED HERO HEADER (220dp) – inside scroll ===== -->
            <FrameLayout
                android:id="@+id/heroHeader"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/blue_600">

                <!-- Dark overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#1A000000" />

                <!-- Back button -->

                <!-- Status + Service name + Order ID -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="24dp"
                    android:background="@drawable/bg_search_bar"
                    android:padding="8dp"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/white" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="24dp"
                    android:layout_marginBottom="28dp">

                    <TextView
                        android:id="@+id/tvStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPCOMING"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_search_bar"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="5dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvServiceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deep Clean"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>

                    <TextView
                        android:id="@+id/tvOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order #O1"
                        android:textSize="13sp"
                        android:textColor="#CCFFFFff"/>
                </LinearLayout>
            </FrameLayout>

            <!-- ===== WHITE CONTENT SHEET (overlaps hero by -28dp) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-28dp"
                android:background="@color/white"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="8dp"
                android:paddingBottom="32dp"
                android:elevation="2dp">

                <!-- ===== CLEANER INFO CARD (floats into hero section) ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/slate_100"
                    android:layout_marginBottom="24dp"
                    android:layout_marginTop="-52dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="26dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="60dp">

                        <!-- Cleaner Avatar -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivCleanerAvatar"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/idol1"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.RoundedSquare"
                            android:layout_marginEnd="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cleaner"
                                android:textSize="11sp"
                                android:textColor="@color/slate_500"
                                android:fontFamily="sans-serif-medium"/>

                            <TextView
                                android:id="@+id/tvCleanerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sarah Jenkins"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/slate_900"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_star"
                                    app:tint="@color/yellow_400"/>

                                <TextView
                                    android:id="@+id/tvCleanerRating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="4.9"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/slate_700"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Phone button -->
                        <FrameLayout
                            android:id="@+id/btnCall"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_circle_blue"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_call"
                                android:layout_gravity="center"
                                app:tint="@color/blue_700"/>
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ===== JOB DETAILS ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Job Details"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_900"
                    android:layout_marginBottom="16dp"/>

                <!-- Date & Time row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@color/slate_50"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            android:layout_gravity="center"
                            app:tint="@color/slate_500"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date &amp; Time"
                            android:textSize="11sp"
                            android:textColor="@color/slate_500"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvDateTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Oct 24, 2023 • 09:00 AM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/slate_800"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="32dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@color/slate_50"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_location"
                            android:layout_gravity="center"
                            app:tint="@color/slate_500"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textSize="11sp"
                            android:textColor="@color/slate_500"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="123 Main St, New York"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/slate_800"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== PAYMENT SUMMARY ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Summary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/slate_900"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/slate_50"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Service Fee (1h)"
                            android:textSize="14sp"
                            android:textColor="@color/slate_600"/>

                        <TextView
                            android:id="@+id/tvPaymentFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$135.00"
                            android:textSize="14sp"
                            android:textColor="@color/slate_600"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tax &amp; Fees"
                            android:textSize="14sp"
                            android:textColor="@color/slate_600"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$5.00"
                            android:textSize="14sp"
                            android:textColor="@color/slate_600"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/slate_200"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/slate_900"/>

                        <TextView
                            android:id="@+id/tvPaymentTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$140.00"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/slate_900"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== ACTION BUTTONS ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="35dp">

                    <LinearLayout
                        android:id="@+id/btnInvoice"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_white_rounded"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_booking"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/slate_600"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Invoice"
                            android:textStyle="bold"
                            android:textColor="@color/slate_600"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnHelp"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_white_rounded"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_support"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/slate_600"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help"
                            android:textStyle="bold"
                            android:textColor="@color/slate_600"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== CHAT WITH CLEANER ===== -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChatCleaner"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="💬  Chat with Cleaner"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_primary"
                    app:backgroundTint="@color/white"
                    app:strokeColor="@color/app_primary"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="28dp"
                    android:layout_marginBottom="12dp"/>

                <!-- ===== REBOOK BUTTON ===== -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRebook"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Rebook Service"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/blue_600"
                    app:cornerRadius="30dp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
