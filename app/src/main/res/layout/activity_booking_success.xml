<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp"
    tools:context=".BookingSuccessActivity">

    <View
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:background="@drawable/bg_success_circle"
        android:layout_marginBottom="24dp" />

    <!-- Title -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="-94dp"
        android:layout_marginBottom="48dp"
        android:src="@drawable/ic_check"
        app:tint="@color/white"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Booking Confirmed!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/slate_900"
        android:layout_marginBottom="8dp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your cleaner will arrive at the scheduled time.\nWe've sent a confirmation email."
        android:textSize="14sp"
        android:textColor="@color/slate_500"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="32dp" />

    <!-- Back to Home Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackToHome"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Back to Home"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        app:backgroundTint="@color/slate_900"
        app:cornerRadius="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewBookingDetail"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="View Booking Detail"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:cornerRadius="16dp"
        app:strokeColor="@color/slate_300"
        app:strokeWidth="1dp"
        android:textColor="@color/slate_700" />

</LinearLayout>
